# ─── LLM Provider ────────────────────────────────────────────────────────────
# "openai" = usa API real (default) | "mock" = sem API key, respostas offline
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ─── Cloud Providers ──────────────────────────────────────────────────────────
# "mock" = dados locais (default) | "real" = chama SDK real
# Troque individualmente conforme migrar para produção:
CLOUD_AWS_MODE=mock    # mock -> real: instala boto3 e configura AWS_PROFILE
CLOUD_GCP_MODE=mock    # mock -> real: instala google-cloud-* e GOOGLE_APPLICATION_CREDENTIALS
CLOUD_AZURE_MODE=mock  # mock -> real: instala azure-mgmt-* e AZURE_SUBSCRIPTION_ID

# AWS real (necessário se CLOUD_AWS_MODE=real)
# AWS_PROFILE=default
# AWS_DEFAULT_REGION=us-east-1

# GCP real (necessário se CLOUD_GCP_MODE=real)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/key.json
# GCP_PROJECT_ID=my-project

# Azure real (necessário se CLOUD_AZURE_MODE=real)
# AZURE_SUBSCRIPTION_ID=xxx
# AZURE_TENANT_ID=xxx
# AZURE_CLIENT_ID=xxx
# AZURE_CLIENT_SECRET=xxx

# ─── Storage ─────────────────────────────────────────────────────────────────
STORAGE_PATH=./storage/reports
VECTOR_DB_PATH=./storage/vector_db
INPUT_FILE=mock_data_multi_agent_governanca.md

# ─── Misc ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
FAILURE_RATE=0.0   # Injetar falha nos cloud mocks (0.0-1.0)
